# Database
DATABASE_URL="postgresql://postgres:password@localhost:5432/spayon_onboarding?schema=public"

# NextAuth
NEXTAUTH_URL="http://localhost:3000"
NEXTAUTH_SECRET="your-secret-key-change-in-production"

# App
NEXT_PUBLIC_APP_URL="http://localhost:3000"
NEXT_PUBLIC_APP_NAME="Spayon Onboarding"

# Supabase Storage (for logo uploads)
SUPABASE_URL="https://your-project.supabase.co"
SUPABASE_SERVICE_ROLE_KEY="your-service-role-key"

# Seed (required when running prisma/seed.ts)
ADMIN_EMAIL="admin@example.com"
ADMIN_PASSWORD="change-me-in-production"
ADMIN_NAME="Admin"
